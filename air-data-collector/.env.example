# ============================================
# 空气质量数据采集系统 - 环境变量配置示例
# 复制此文件为 .env 并修改配置值
# ============================================

# 应用配置
DEBUG=false
APP_NAME=AirQualityCollector
APP_VERSION=1.0.0

# API配置
API_BASE_URL=http://www.cnemc.cn
API_TIMEOUT=30
REQUEST_RETRY_TIMES=3
REQUEST_RETRY_DELAY=1.0
REQUEST_RATE_LIMIT=0.5

# 数据存储
OUTPUT_FORMAT=both
OUTPUT_DIR=./data
LOG_DIR=./logs

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=air_quality_db
DB_USER=root
DB_PASSWORD=your_password

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
